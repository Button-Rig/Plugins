{
  "author":"buttonrig",
  "name": "System",
  "version": "1.0.0",
  "targetVersion": "br_plugins_1.0",
  "icon": "icons/computer.svg",
  "handlerCli": [
    {
      "target": "x86_64-pc-windows-msvc",
      "path": "handler-cli-x86_64-windows.exe"
    },
    {
      "target": "x86_64-unknown-linux-gnu",
      "path": "handler-cli-x86_64-linux"
    }
  ],
  "components": [
    {
      "name": "Copy to Clipboard",
      "urlPath": "clipboard",
      "type": "action",
      "icon": "icons/clipboard.svg",
      "actionConfig": {
        "configuratorHeightInPx": 150,
        "executionLabel": "Coying to Clipboard"
      },
      "security": {
        "riskLevel": "high",
        "warning": "Malicious scripts could be copied to your clipboard."
      }
    },
    {
      "name": "Delay",
      "urlPath": "delay",
      "type": "action",
      "icon": "icons/clock.svg",
      "actionConfig": {
        "configuratorHeightInPx": 70,
        "executionLabel": "Delaying"
      },
      "security": {
        "riskLevel": "none"
      }
    },
    {
      "name": "Open File",
      "urlPath": "file",
      "type": "action",
      "icon": "icons/file.svg",
      "actionConfig": {
        "configuratorHeightInPx": 70,
        "executionLabel": "Opening file"
      },
      "security": {
        "riskLevel": "high",
        "warning": "The included file could be malicious."
      }
    },
    {
      "name": "Open Folder",
      "urlPath": "folder",
      "type": "action",
      "icon": "icons/folder.svg",
      "actionConfig": {
        "configuratorHeightInPx": 70,
        "executionLabel": "Opening folder"
      },
      "security": {
        "riskLevel": "high",
        "warning": "The included folder could contain malicious content."
      }
    },
    {
      "name": "Open Website",
      "urlPath": "website",
      "type": "action",
      "icon": "icons/globe.svg",
      "actionConfig": {
        "configuratorHeightInPx": 70,
        "executionLabel": "Opening website"
      },
      "security": {
        "riskLevel": "high",
        "warning": "The website being opened could be malicious."
      }
    },
    {
      "name": "Run Command",
      "urlPath": "command",
      "type": "action",
      "icon": "icons/greater-than.svg",
      "actionConfig": {
        "configuratorHeightInPx": 150,
        "executionLabel": "Running command"
      },
      "security": {
        "riskLevel": "high",
        "warning": "The command set to run could be malicious."
      }
    }
  ]
}
